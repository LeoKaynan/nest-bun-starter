{
  "name": "nest-bun-starter",
  "version": "0.0.1",
  "description": "NestJS boilerplate running entirely on Bun, with the native TypeScript 7 compiler, Biome, ES Modules, and a portable single-file binary build.",
  "author": "LeoKaynan",
  "license": "MIT",
  "private": true,
  "type": "module",
  "keywords": [
    "nestjs",
    "bun",
    "typescript",
    "typescript-7",
    "biome",
    "esm",
    "boilerplate",
    "starter",
    "template"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeoKaynan/nest-bun-starter.git"
  },
  "homepage": "https://github.com/LeoKaynan/nest-bun-starter#readme",
  "bugs": {
    "url": "https://github.com/LeoKaynan/nest-bun-starter/issues"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "prepare": "lefthook install || true",
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "start": "bun run src/main.ts",
    "start:dev": "bun --watch src/main.ts",
    "start:debug": "bun --inspect --watch src/main.ts",
    "start:prod": "./dist/main",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "test": "bun test src",
    "test:watch": "bun test --watch src",
    "test:cov": "bun test --coverage src",
    "test:e2e": "bun test ./test/app.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bun": "^1.3.14",
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.0.0",
    "lefthook": "^2.1.10",
    "supertest": "^7.0.0",
    "typescript": "7.0.2"
  }
}
